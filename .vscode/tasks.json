{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build Astral",
      "type": "shell",
      "command": "cl /EHsc /std:c++20 /utf-8 /I. source\\main.cpp core\\*.cpp runtime\\*.cpp /Fe:Astral.exe",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "build skill_mem",
      "type": "shell",
      "command": "cl /EHsc /std:c++20 /utf-8 skill_src\\skill_mem_main.cpp /Fe:skills\\skill_mem.exe",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "group": "build",
      "problemMatcher": ["$msCompile"]
    }
  ]
}